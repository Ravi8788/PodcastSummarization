# Frontend (Vite) env vars
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=public-anon-key

# Edge function / server secrets
LOVABLE_API_KEY=

# Optional: indicate development for function fallback
DENO_ENV=development

# You can copy this to .env and fill values for local development